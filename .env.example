# ============================================
# telegram knowledge-graph — Environment Template
# Copy to .env and fill in values. NEVER commit .env.
# ============================================

# --- Telegram bot (the channel poller; var name historical, kept for stability) ---
# Created via @BotFather. Privacy mode MUST be DISABLED before adding to channel.
# USERNAME is just the bot's @handle (without @); used in error messages.
TELEGRAM_BRIDG3BOT_USERNAME=
TELEGRAM_BRIDG3BOT_TOKEN=
# Captured automatically by setup_wizard once the bot is in the channel and a test message is posted.
TELEGRAM_BRIDG3BOT_CHAT_ID=

# --- Telegram MTProto (for Telethon historical backfill, runs as your user account) ---
# Get these once at https://my.telegram.org -> API Development Tools -> create app.
# Phone number is prompted interactively the first time you run backfill_telethon.py.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Telegram owner DM (status pings; bot can only DM you after you've sent it /start once) ---
TELEGRAM_OWNER_CHAT_ID=

# --- Classifier (Phase 2) — runs through local `claude` CLI, NOT Anthropic API ---
# Uses your Claude Code subscription, so no API key needed for this project.
# Model alias: "haiku" | "sonnet" | "opus" (auto-resolves to latest), or pin
# a full name like "claude-haiku-4-5".
# Workers: parallel `claude` subprocesses. Recommend 3 on Claude Max, 1-2 on Pro.
CLAWRYDERZ_CLASSIFY_MODEL=haiku
CLAWRYDERZ_CLASSIFY_WORKERS=3

# --- Anthropic API key (only needed if you ever want to bypass the CLI) ---
# Currently unused — classify and summarize both go via CLI.
# Leave blank unless you have a specific reason.
ANTHROPIC_API_KEY=

# --- Site auth (HMAC-signed cookie session via Cloudflare Pages middleware) ---
# SITE_USERNAME / SITE_PASSWORD gate the deployed Quartz site. Pick a strong
# password (e.g. `openssl rand -base64 24`).
SITE_USERNAME=
SITE_PASSWORD=

# --- GitHub (used by daily orchestrator to push vault commits) ---
GITHUB_USER=
GITHUB_EMAIL=

# --- Cloudflare (Pages deploy / DNS) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
