# ============================================
# telegram knowledge-graph — Environment Template
# Copy to .env and fill in values. NEVER commit .env.
# ============================================

# --- Telegram Bridg3bot (the channel poller) ---
# Created via @BotFather. Privacy mode MUST be DISABLED.
TELEGRAM_BRIDG3BOT_USERNAME=
TELEGRAM_BRIDG3BOT_TOKEN=
# Captured automatically by setup_wizard once the bot is in the channel and a test message is posted.
TELEGRAM_BRIDG3BOT_CHAT_ID=

# --- Telegram MTProto (for Telethon historical backfill, runs as your user account) ---
# Get these once at https://my.telegram.org -> API Development Tools -> create app.
# Phone number is prompted interactively the first time you run backfill_telethon.py.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Telegram owner DM (status pings; bot can only DM you after you've sent it /start once) ---
TELEGRAM_OWNER_CHAT_ID=

# --- Classifier (Phase 2) — runs through local `claude` CLI, NOT Anthropic API ---
# Uses your Claude Code subscription, so no API key needed for this project.
# Model alias: "haiku" | "sonnet" | "opus" (auto-resolves to latest), or pin
# a full name like "claude-haiku-4-5".
# Workers: parallel `claude` subprocesses. Recommend 3 on Claude Max, 1-2 on Pro.
CLAWRYDERZ_CLASSIFY_MODEL=haiku
CLAWRYDERZ_CLASSIFY_WORKERS=3

# --- Anthropic API key (only needed if you ever want to bypass the CLI) ---
# This project does NOT need an API key. Classify, summarize, digest, and the
# Ask chat panel all route through the local `claude` CLI (Claude Max).
#
# WARNING: if you have ANTHROPIC_API_KEY set for OTHER tools that share this
# .env, the claude CLI will prefer the API key over your Max OAuth token and
# silently route to API mode. ask_server.py auto-strips it from its subprocess
# env when CLAUDE_CODE_OAUTH_TOKEN is set; other modules that shell out to
# claude may not. Leave blank unless you specifically need API-mode auth.
ANTHROPIC_API_KEY=

# --- Claude Code OAuth token (REQUIRED for the chat panel under launchd) ---
# Why: launchd-spawned subprocesses can't read the macOS keychain, so `claude
# -p` from ask_server.py can't find your Max session and falls back to API
# mode → "Credit balance is too low" on every model. Fix is a long-lived
# OAuth token loaded from this file into the subprocess env.
#
# Generate with:
#   claude setup-token
# Paste the resulting `sk-ant-oat01-...` value below on a SINGLE LINE
# (the terminal may wrap it visually; dotenv only reads the first line of
# any value, so combine wraps before saving). Token is valid for ~1 year.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Site auth (HTTP Basic Auth via Cloudflare Pages middleware) ---
SITE_USERNAME=
SITE_PASSWORD=

# --- GitHub (used by daily orchestrator to push vault commits) ---
GITHUB_USER=
GITHUB_EMAIL=

# --- Cloudflare (Pages deploy / DNS) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# --- Ask Bridg3 (website chat panel; FastAPI on the Mac mini, exposed via cloudflared) ---
# Generate with: openssl rand -hex 32
# Set the SAME value here AND on your Cloudflare Pages project (Settings →
# Environment variables → ASK_SHARED_SECRET). Pages function uses it as a
# bearer token; ask_server.py validates it. Empty = auth disabled (dev only).
ASK_SHARED_SECRET=
# Model the chat panel uses. Defaults to sonnet if unset.
CLAWRYDERZ_ASK_MODEL=sonnet
# Bind address + port for ask_server.py (cloudflared points at this).
ASK_HOST=127.0.0.1
ASK_PORT=8787

# --- Telegram daily digest (off by default — preview before flipping on) ---
# When 1, the orchestrator posts a 2-3 paragraph narrative digest to the channel
# nightly. Preview first: `agent/.venv/bin/python -m src.digest --preview`.
TELEGRAM_DIGEST_ENABLED=
# Override the post target (defaults to TELEGRAM_BRIDG3BOT_CHAT_ID).
# Useful for testing — set this to TELEGRAM_OWNER_CHAT_ID to send the digest to
# yourself instead of the channel until tone is dialed in.
TELEGRAM_DIGEST_TARGET=
CLAWRYDERZ_DIGEST_MODEL=sonnet
